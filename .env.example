# ════════════════════════════════════════════════════════════════════════
#  WCNET — Autonomous World Cup short-form video network
#  Copy this file to `.env` and fill in real values. Never commit `.env`.
# ════════════════════════════════════════════════════════════════════════

# ── General runtime ──────────────────────────────────────────────────────
WCNET_ENV=production
WCNET_LOG_LEVEL=INFO
WCNET_DATA_DIR=./data            # state DB, token caches, rendered clips, buffer

# ── Football data (API-Football v3) ──────────────────────────────────────
# Either the direct host (api-football v3) OR via RapidAPI. Set the host that
# matches your subscription. RapidAPI users: set the RapidAPI host + key.
FOOTBALL_API_KEY=replace_me
FOOTBALL_API_HOST=v3.football.api-sports.io        # or: api-football-v1.p.rapidapi.com
FOOTBALL_API_VIA_RAPIDAPI=false                    # true if using RapidAPI gateway
# League id for the FIFA World Cup on API-Football is 1. Season is the year.
FOOTBALL_LEAGUE_ID=1
FOOTBALL_SEASON=2026
FOOTBALL_POLL_SECONDS=60                            # schedule/event poll cadence

# ── YouTube Data API v3 (Search + Shorts upload) ─────────────────────────
# Search uses an API key. Upload uses OAuth (client_secrets.json downloaded
# from Google Cloud Console). Token is cached after first interactive auth.
YOUTUBE_API_KEY=replace_me
YOUTUBE_CLIENT_SECRETS=./secrets/client_secrets.json
YOUTUBE_TOKEN_CACHE=./data/youtube_token.json
YOUTUBE_CATEGORY_ID=17                              # 17 = Sports
YOUTUBE_PRIVACY=public                              # public | unlisted | private

# ── TikTok Content Posting API ───────────────────────────────────────────
TIKTOK_CLIENT_KEY=replace_me
TIKTOK_CLIENT_SECRET=replace_me
# Long-lived user refresh token obtained once via the OAuth consent flow.
TIKTOK_REFRESH_TOKEN=replace_me
TIKTOK_TOKEN_CACHE=./data/tiktok_token.json
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE            # or SELF_ONLY for sandbox tests

# ── Meta / Instagram Graph API (Reels) ───────────────────────────────────
IG_USER_ID=replace_me                              # Instagram Business/Creator id
IG_ACCESS_TOKEN=replace_me                         # long-lived Page/IG token
IG_GRAPH_VERSION=v19.0

# ── Cloudflare R2 (S3-compatible) — public URL host for IG ingestion ─────
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET=wcnet-clips
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# Public base URL (R2 public bucket or a custom domain bound to the bucket).
R2_PUBLIC_BASE_URL=https://clips.example.com

# ── Capture / render tuning ──────────────────────────────────────────────
CAPTURE_PRE_SECONDS=18           # seconds of build-up before the trigger
CAPTURE_POST_SECONDS=10          # seconds after the trigger
BUFFER_WINDOW_SECONDS=240        # rolling DVR buffer kept on disk
SEGMENT_SECONDS=2                # granularity of buffer segments
RENDER_MODE=blur_pad             # blur_pad | center_crop
FFMPEG_BINARY=ffmpeg
