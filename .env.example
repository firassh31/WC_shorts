# ════════════════════════════════════════════════════════════════════════
#  WCNET — Autonomous World Cup short-form video network
#  Copy this file to `.env` and fill in real values. Never commit `.env`.
# ════════════════════════════════════════════════════════════════════════

# ── General runtime ──────────────────────────────────────────────────────
WCNET_ENV=production
WCNET_LOG_LEVEL=INFO
WCNET_DATA_DIR=./data            # state DB, token caches, rendered clips, buffer

# ── Football data (API-Football v3) ──────────────────────────────────────
# Either the direct host (api-football v3) OR via RapidAPI. Set the host that
# matches your subscription. RapidAPI users: set the RapidAPI host + key.
FOOTBALL_API_KEY=replace_me
FOOTBALL_API_HOST=v3.football.api-sports.io        # or: api-football-v1.p.rapidapi.com
FOOTBALL_API_VIA_RAPIDAPI=false                    # true if using RapidAPI gateway
# League id for the FIFA World Cup on API-Football is 1. Season is the year.
FOOTBALL_LEAGUE_ID=1
FOOTBALL_SEASON=2026
FOOTBALL_POLL_SECONDS=60                            # schedule/event poll cadence

# ── YouTube OAuth (used ONLY to search for the live stream) ──────────────
# OAuth client_secrets.json downloaded from Google Cloud Console; the token is
# cached after the first interactive auth. No upload — there is no publishing.
YOUTUBE_CLIENT_SECRETS=./secrets/client_secrets.json
YOUTUBE_TOKEN_CACHE=./data/youtube_token.json

# ── Capture / render tuning ──────────────────────────────────────────────
CAPTURE_PRE_SECONDS=18           # seconds of build-up before the trigger
CAPTURE_POST_SECONDS=10          # seconds after the trigger
BUFFER_WINDOW_SECONDS=240        # rolling DVR buffer kept on disk
SEGMENT_SECONDS=2                # granularity of buffer segments
RENDER_MODE=blur_pad             # blur_pad | center_crop
FFMPEG_BINARY=ffmpeg
